{
  "name": "deskdoodle",
  "version": "0.0.0",
  "description": "Draw on your desktop wallpaper with Excalidraw, then make the doodle your background.",
  "keywords": [
    "wallpaper",
    "excalidraw",
    "gnome",
    "desktop",
    "doodle",
    "linux",
    "cli"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artificiadrian/deskdoodle.git"
  },
  "bugs": {
    "url": "https://github.com/artificiadrian/deskdoodle/issues"
  },
  "homepage": "https://github.com/artificiadrian/deskdoodle#readme",
  "type": "module",
  "bin": {
    "deskdoodle": "./dist/cli/deskdoodle.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22"
  },
  "os": [
    "linux"
  ],
  "scripts": {
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json",
    "build": "esbuild src/cli/deskdoodle.ts --bundle --packages=external --platform=node --format=esm --target=node22 --outfile=dist/cli/deskdoodle.js && chmod +x dist/cli/deskdoodle.js && vite build",
    "start": "node dist/cli/deskdoodle.js",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@excalidraw/excalidraw": "^0.18.1",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "esbuild": "0.28.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^5.9.3",
    "vite": "^7.3.6"
  },
  "packageManager": "pnpm@11.9.0"
}
