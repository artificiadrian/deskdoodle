{
  "name": "deskdoodle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "deskdoodle": "./dist/cli/deskdoodle.js"
  },
  "scripts": {
    "typecheck": "pnpm typecheck:node && pnpm typecheck:web",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit",
    "typecheck:web": "tsc -p tsconfig.web.json",
    "build": "pnpm build:node && pnpm build:web",
    "build:node": "tsc -p tsconfig.node.json && chmod +x dist/cli/deskdoodle.js",
    "build:web": "vite build",
    "link:global": "pnpm build && pnpm link --global",
    "deskdoodle": "pnpm build && node dist/cli/deskdoodle.js",
    "start": "node dist/cli/deskdoodle.js"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@vitejs/plugin-react": "^5.0.0",
    "commander": "^14.0.0",
    "picocolors": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
