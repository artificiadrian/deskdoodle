{
  "name": "deskdoodle",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "deskdoodle": "./dist/cli/deskdoodle.js"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.node.json",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "deskdoodle": "pnpm build && node dist/cli/deskdoodle.js",
    "start": "node dist/cli/deskdoodle.js"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@vitejs/plugin-react": "^5.0.0",
    "vite": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.8.0"
  }
}
