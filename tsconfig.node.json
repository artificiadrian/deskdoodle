{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "types": ["node"],

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "noEmit": true
  },
  "include": [
    "src/cli/**/*.ts",
    "src/server/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": [
    "src/editor",
    "dist",
    "node_modules"
  ]
}
